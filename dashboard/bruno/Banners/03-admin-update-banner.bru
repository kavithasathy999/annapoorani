meta {
  name: PUT Update Banner
  type: http
}

put {
  url: {{baseUrl}}/banners/1
}

headers {
  Authorization: Bearer {{authToken}}
}

body:multipart-form {
  name: Summer Sale Banner Updated
  link: /website/products
  sort_order: 2
  is_active: 1
  image: "C:\\replace-with-image\\banner-updated.png"
}
