  why_choose_pillar_4_title: Trusted Brand
  why_choose_pillar_4_text: Thousands of happy customers rely on us season after season.
  why_choose_stat_1_label: Availability
  why_choose_stat_1_value: 100
  why_choose_stat_2_label: Best Delivery
  why_choose_stat_2_value: 100
  why_choose_stat_3_label: Easy Ordering
  why_choose_stat_3_value: 100
  why_choose_stat_4_label: Customer Support
  why_choose_stat_4_value: 100
  why_choose_bottom_1_value: 5000+
  why_choose_bottom_1_label: Happy Customers
  why_choose_bottom_2_value: 200+
  why_choose_bottom_2_label: Products
