meta {
  name: PUT Homepage Settings
  type: http
}

put {
  url: {{baseUrl}}/settings/homepage
}

headers {
  Authorization: Bearer {{authToken}}
}

body:multipart-form {
  hero_eyebrow: WELCOME TO SPARKLE
  hero_heading_html: <p>Welcome to<br />The Bluvel Crackers!</p>
  hero_description_html: <p>Since 2026, <strong>The Bluvel Crackers</strong> has been the No.1 destination for all your celebration needs.</p><p>We have the perfect crackers to make every occasion unforgettable.</p>
